{
  "expo": {
    "name": "my-report-app",
    "slug": "my-report-app",
    "version": "1.0.0",
    "orientation": "portrait",

    "platforms": ["ios", "android"],

    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,

    "splash": {
      "image": "./src/assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    

    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "يتم استخدام الموقع لمساعدتك في تقديم البلاغات في الأماكن الصحيحة.",
        "NSCameraUsageDescription": "يتم استخدام الكاميرا لالتقاط الصور والفيديوهات المتعلقة بالبلاغ.",
        "NSPhotoLibraryUsageDescription": "يتم استخدام مكتبة الصور لاختيار الصور والفيديوهات لإرفاقها في البلاغ."
      }
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
      
      
    }
    
  }
  
}

